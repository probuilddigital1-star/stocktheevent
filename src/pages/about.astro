---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'About', url: '/about' }
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "StockTheEvent Team",
  "description": "Professional bartenders and event planners with 30+ years of combined experience in the hospitality industry.",
  "jobTitle": "Party Planning Experts",
  "worksFor": {
    "@type": "Organization",
    "name": "StockTheEvent",
    "url": "https://www.stocktheevent.com"
  }
};
---

<BaseLayout
  title="About StockTheEvent - Drink Calculator"
  description="Learn about StockTheEvent and our bartender-tested drink calculation formulas. Never run out (or over-buy) for your event again."
  canonicalUrl="https://www.stocktheevent.com/about"
  breadcrumbs={breadcrumbs}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </Fragment>
  <section class="py-16 bg-gradient-to-b from-amber-50 to-white">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-display font-bold text-[var(--chocolate)] mb-6 text-center">
        About StockTheEvent
      </h1>
      <p class="text-xl text-[var(--chocolate-light)] text-center mb-12">
        Drink calculators that actually work
      </p>

      <div class="prose prose-lg max-w-none">
        <div class="glass-card p-8 mb-8">
          <h2 class="text-2xl font-bold text-[var(--chocolate)] mb-4">The Problem</h2>
          <p class="text-[var(--chocolate-light)] leading-relaxed mb-4">
            Every event planner faces the same dilemma: buy too little alcohol and run out mid-party (disaster), or buy too much and waste money on bottles you'll never open.
          </p>
          <p class="text-[var(--chocolate-light)] leading-relaxed">
            Most online calculators give you a generic "1 drink per person per hour" formula. That might work for a corporate mixer, but it's wildly off for a Super Bowl party or a wedding reception.
          </p>
        </div>

        <div class="glass-card p-8 mb-8">
          <h2 class="text-2xl font-bold text-[var(--chocolate)] mb-4">Our Solution</h2>
          <p class="text-[var(--chocolate-light)] leading-relaxed mb-4">
            StockTheEvent uses formulas refined by bartenders with 30+ years of experience. We factor in:
          </p>
          <ul class="space-y-3 text-[var(--chocolate-light)]">
            <li class="flex items-start gap-3">
              <span class="text-amber-500 font-bold">1.</span>
              <span><strong>Event type modifiers</strong> - Weddings drink 20% more wine, Super Bowl parties drink 40% more beer</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-amber-500 font-bold">2.</span>
              <span><strong>Consumption decay</strong> - People drink faster in the first hour and slow down as the event progresses</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-amber-500 font-bold">3.</span>
              <span><strong>Guest count scaling</strong> - Larger events have a lower percentage of active drinkers</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-amber-500 font-bold">4.</span>
              <span><strong>Safety buffer</strong> - We add 15% to ensure you never run out</span>
            </li>
          </ul>
        </div>

        <div class="glass-card p-8 mb-8">
          <h2 class="text-2xl font-bold text-[var(--chocolate)] mb-4">The Formula</h2>
          <div class="bg-[var(--champagne-100)] rounded-xl p-6 font-mono text-sm text-[var(--chocolate-light)] mb-4">
            <p class="mb-2">Base: 1.5 drinks/person/hour</p>
            <p class="mb-2">Adjusted for: consumption decay curve</p>
            <p class="mb-2">Modified by: event type (+/-)</p>
            <p class="mb-2">Scaled by: guest count tier</p>
            <p>Buffer: +15% safety margin</p>
          </div>
          <p class="text-[var(--chocolate-light)] leading-relaxed">
            The result? Accurate drink counts that match real-world event consumption patterns.
          </p>
        </div>

        <div class="glass-card p-8">
          <h2 class="text-2xl font-bold text-[var(--chocolate)] mb-4">Our Mission</h2>
          <p class="text-[var(--chocolate-light)] leading-relaxed">
            We believe everyone deserves to throw a great party without the stress of running out of drinks or wasting money on over-buying.
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a
          href="/"
          class="inline-block sunset-gradient text-white font-bold py-4 px-8 rounded-xl hover:scale-105 transition-transform text-lg"
        >
          Try the Calculator
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
