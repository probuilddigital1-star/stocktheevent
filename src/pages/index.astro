---
import BaseLayout from '../layouts/BaseLayout.astro';
import InteractiveCalculator from '../components/InteractiveCalculator.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { affiliateLinks } from '../lib/affiliates';
---

<BaseLayout
  title="Party Food & Drink Calculator — StockTheEvent"
  description="Calculate exactly how much food and drinks you need for your event. Bartender-tested formulas for weddings, birthdays, Super Bowl parties, and more. Wine, beer, pizza, wings & more."
>
  <!-- Interactive Calculator Hero -->
  <InteractiveCalculator />

  <!-- Why Trust Our Calculator (moved up for credibility-first) -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-[var(--chocolate)] mb-12 text-center">
        Why Trust Our Calculator?
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-[var(--primary-10)] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">🎯</span>
          </div>
          <h3 class="font-bold text-lg mb-2">Industry Standards</h3>
          <p class="text-[var(--chocolate-light)] text-sm">Based on the 1.5 drinks per hour rule used by professional bartenders worldwide.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-[var(--primary-10)] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">📉</span>
          </div>
          <h3 class="font-bold text-lg mb-2">Smart Scaling</h3>
          <p class="text-[var(--chocolate-light)] text-sm">We factor in that people drink less as events progress - so you don't over-buy.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-[var(--primary-10)] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">🎊</span>
          </div>
          <h3 class="font-bold text-lg mb-2">Event-Specific</h3>
          <p class="text-[var(--chocolate-light)] text-sm">Weddings drink more wine, game day parties need more beer. We adjust for each event.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Calculators -->
  <section class="py-16 bg-[var(--champagne-100)]">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-[var(--chocolate)] mb-8 text-center">
        Popular Calculators
      </h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="/wine-for-wedding-100-guests" class="glass-card p-5 rounded-xl hover:border-[var(--primary)] hover:shadow-md transition-all group">
          <div class="flex items-center gap-4">
            <span class="text-3xl">🍷</span>
            <div>
              <div class="font-bold text-[var(--chocolate)] group-hover:text-[var(--primary-dark)]">Wine for 100 Guest Wedding</div>
              <div class="text-sm text-[var(--chocolate-40)]">Most popular calculator</div>
            </div>
          </div>
        </a>
        <a href="/party/march-madness-party-calculator" class="glass-card p-5 rounded-xl hover:border-[var(--primary)] hover:shadow-md transition-all group">
          <div class="flex items-center gap-4">
            <span class="text-3xl">🏀</span>
            <div>
              <div class="font-bold text-[var(--chocolate)] group-hover:text-[var(--primary-dark)]">March Madness Party Calculator</div>
              <div class="text-sm text-[var(--chocolate-40)]">Bracket party planning</div>
            </div>
          </div>
        </a>
        <a href="/champagne-for-holiday-party-75-guests" class="glass-card p-5 rounded-xl hover:border-[var(--primary)] hover:shadow-md transition-all group">
          <div class="flex items-center gap-4">
            <span class="text-3xl">🥂</span>
            <div>
              <div class="font-bold text-[var(--chocolate)] group-hover:text-[var(--primary-dark)]">Champagne for 75 Guest Holiday Party</div>
              <div class="text-sm text-[var(--chocolate-40)]">Celebrate in style</div>
            </div>
          </div>
        </a>
        <a href="/spirits-for-birthday-party-30-guests" class="glass-card p-5 rounded-xl hover:border-[var(--primary)] hover:shadow-md transition-all group">
          <div class="flex items-center gap-4">
            <span class="text-3xl">🥃</span>
            <div>
              <div class="font-bold text-[var(--chocolate)] group-hover:text-[var(--primary-dark)]">Spirits for 30 Guest Birthday</div>
              <div class="text-sm text-[var(--chocolate-40)]">Party planning made easy</div>
            </div>
          </div>
        </a>
      </div>
      <div class="text-center mt-8">
        <a href="/calculators" class="text-[var(--primary-dark)] hover:text-[var(--primary)] font-medium hover:underline">
          View all 1,820+ calculators →
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-[var(--chocolate)] mb-4">
        Trusted by Event Planners
      </h2>
      <p class="text-[var(--chocolate-light)] mb-8">
        Our formulas are based on industry standards and refined by bartenders with decades of experience.
      </p>
      <div class="flex justify-center gap-8 text-[var(--chocolate-40)]">
        <div class="text-center">
          <div class="text-4xl font-bold text-[var(--primary)]">30+</div>
          <div class="text-sm">Years Experience</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-[var(--primary)]">1,820+</div>
          <div class="text-sm">Calculators</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-[var(--primary)]">15%</div>
          <div class="text-sm">Safety Buffer</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Email Capture -->
  <section class="py-12 bg-gradient-to-b from-[var(--champagne-100)] to-white">
    <div class="max-w-3xl mx-auto px-4">
      <EmailCapture eventType="homepage" placement="inline" />
    </div>
  </section>

  <!-- Pro Tip: Stock Your Bar (Affiliate Links) -->
  <section class="py-12 bg-[var(--champagne-100)]">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="font-display text-2xl font-bold text-[var(--chocolate)] mb-2">
          Pro Tip: Stock Your Bar
        </h2>
        <p class="text-[var(--chocolate-light)] text-sm">
          Essential supplies every host needs
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-3">
        <a href={affiliateLinks['party-cups']} target="_blank" rel="noopener sponsored" class="flex items-center gap-3 p-4 rounded-xl glass-card hover:border-[var(--primary)] hover:shadow-md transition-all group">
          <span class="text-3xl">🥤</span>
          <div class="flex-1">
            <div class="font-medium text-[var(--chocolate)] group-hover:text-[var(--primary-dark)]">Party Cups</div>
            <div class="text-sm text-[var(--chocolate-40)]">For beer, cocktails & more</div>
          </div>
        </a>
        <a href={affiliateLinks['wine-glasses']} target="_blank" rel="noopener sponsored" class="flex items-center gap-3 p-4 rounded-xl glass-card hover:border-[var(--primary)] hover:shadow-md transition-all group">
          <span class="text-3xl">🍷</span>
          <div class="flex-1">
            <div class="font-medium text-[var(--chocolate)] group-hover:text-[var(--primary-dark)]">Wine Glasses</div>
            <div class="text-sm text-[var(--chocolate-40)]">Elegant party stemware</div>
          </div>
        </a>
        <a href={affiliateLinks['ice-bucket']} target="_blank" rel="noopener sponsored" class="flex items-center gap-3 p-4 rounded-xl glass-card hover:border-[var(--primary)] hover:shadow-md transition-all group">
          <span class="text-3xl">🪣</span>
          <div class="flex-1">
            <div class="font-medium text-[var(--chocolate)] group-hover:text-[var(--primary-dark)]">Ice Bucket</div>
            <div class="text-sm text-[var(--chocolate-40)]">Keep bottles chilled</div>
          </div>
        </a>
        <a href={affiliateLinks['corkscrew']} target="_blank" rel="noopener sponsored" class="flex items-center gap-3 p-4 rounded-xl glass-card hover:border-[var(--primary)] hover:shadow-md transition-all group">
          <span class="text-3xl">🔧</span>
          <div class="flex-1">
            <div class="font-medium text-[var(--chocolate)] group-hover:text-[var(--primary-dark)]">Wine Opener</div>
            <div class="text-sm text-[var(--chocolate-40)]">Every bar needs one</div>
          </div>
        </a>
      </div>

      <p class="text-xs text-[var(--chocolate-40)] text-center mt-6">
        As an Amazon Associate, we earn from qualifying purchases at no extra cost to you.
      </p>
    </div>
  </section>

  <!-- Cross-promotion: FreezerBatchCocktails -->
  <section class="py-10 bg-white border-y border-[var(--primary-10)]">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <p class="text-3xl mb-2">🍸</p>
      <h2 class="font-display text-xl font-bold text-[var(--chocolate)] mb-2">
        Be the Host, Not the Bartender
      </h2>
      <p class="text-[var(--chocolate-light)] mb-4">
        Dinner party for 8? Batch your Negronis and Manhattans ahead of time. Perfectly chilled, zero effort.
      </p>
      <a
        href="https://freezerbatchcocktails.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block sunset-gradient text-white px-6 py-2 rounded-xl font-semibold hover:shadow-lg hover:scale-105 transition-all"
      >
        Explore Freezer Batching →
      </a>
    </div>
  </section>
</BaseLayout>
